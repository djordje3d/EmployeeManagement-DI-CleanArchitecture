@model List<Kvalifikacija>

    <style>
    .active {
        font-weight: bold;
        color: red; /* Ili neka druga boja po izboru */
        text-decoration: underline;
    }
    </style>

<div class="container mt-4">
    <h3 class="text-center mb-4">Kvalifikacije</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="id">ID Kvalifikacija</a>
                            <a asp-action="Index" asp-route-sortOrder="id_desc">↓</a>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="LicniStepenKv" class="@((string)ViewData["CurrentSort"] == "LicniStepenKv" ? "active" : "")">Lični Stepen Kv</a>
                            <a asp-action="Index" asp-route-sortOrder="LicniStepenKv_desc" class="@((string)ViewData["CurrentSort"] == "LicniStepenKv_desc" ? "active" : "")">↓</a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="Naziv" class="@((string)ViewData["CurrentSort"] == "Naziv" ? "active" : "")">Naziv</a>
                            <a asp-action="Index" asp-route-sortOrder="Naziv_desc" class="@((string)ViewData["CurrentSort"] == "Naziv_desc" ? "active" : "")">↓</a>
                        </th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kvalifikacija in Model)
                    {
                        <tr>
                            <td>@kvalifikacija.Id</td>
                            <td>@kvalifikacija.LicniStepenKv</td>
                            <td>@kvalifikacija.Naziv</td>
                            <td>
                                <a class="btn btn-sm btn-warning" asp-action="UpdateKvalifikacija" asp-route-kvalifikacijaId="@kvalifikacija.Id">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a class="btn btn-sm btn-danger" asp-action="DeleteKvalifikacija" asp-route-kvalifikacijaId="@kvalifikacija.Id" onclick="return confirm('Da li ste sigurni da želite da obrišete ovu kvalifikaciju?');">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-center">Nema kvalifikacija.</p>
    }

    <div class="text-center mt-4">
        <a class="btn btn-primary btn-lg" asp-controller="Kvalifikacije" asp-action="AddKvalifikacija">
            <i class="bi bi-plus-lg"></i> Add New Kvalifikacija
        </a>
    </div>
</div>

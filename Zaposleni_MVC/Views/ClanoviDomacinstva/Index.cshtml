@model List<ClanoviDomacinstva>

<div class="container mt-4">
    <div class="text-danger" asp-validation-summary="All"></div>

    <h3 class="text-center mb-4">Članovi domaćinstva</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Id člana</th>
                        <th>Id radnik</th>
                        <th>Ime</th>
                        <th>Pol</th>
                        <th>Datum rođenja člana</th>
                        <th>Srodstvo člana</th>
                        <th>Status člana</th>
                        <th>JMBG</th>
                        <th>Roditelj</th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var clan in Model)
                    {
                        <tr>
                            <td>@clan.Id</td>
                            <td>@(clan.Zaposlen != null ? clan.Zaposlen.Id.ToString() : "N/A")</td> <!-- Prikazuje Id zaposlenog ili "N/A" ako je null -->
                            <td>@clan.ImeClana</td>
                            <td>@clan.PolClana</td>
                            <td>@clan.DatumRodjenjaClana?.ToString("dd.MM.yyyy")</td>
                            <td>@clan.SroClana</td>
                            <td>@clan.StatusClana</td>
                            <td>@clan.JMBG</td>
                            <td>@clan.Roditelj</td>
                            <td>
                                <a class="btn btn-sm btn-warning" asp-action="UpdateClanDomacinstva" asp-route-clanId="@clan.Id">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a class="btn btn-sm btn-danger" asp-action="DeleteClanDomacinstva" asp-route-clanId="@clan.Id" onclick="return confirm('Da li ste sigurni da želite da obrišete ovog člana?');">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-center">Nema zaposlenih.</p>
    }

    <div class="text-center mt-4">
        <a class="btn btn-primary btn-lg" asp-controller="ClanoviDomacinstva" asp-action="AddClanDomacinstva">
            <i class="bi bi-plus-lg"></i> Add new član
        </a>
    </div>
</div>

<!-- Include Bootstrap Icons -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.8.1/font/bootstrap-icons.min.css" rel="stylesheet">

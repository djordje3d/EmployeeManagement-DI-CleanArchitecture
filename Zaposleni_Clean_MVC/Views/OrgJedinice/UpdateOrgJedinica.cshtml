@model OrganizacioneJedinice

<div class="container mt-4" style="max-width: 50%;">
    <h3 class="text-center mb-4">Izmeni OJ</h3>

    <div class="card shadow-lg">
        <div class="card-body">
            <form method="post" asp-action="UpdateOrgJedinica">
                <input type="hidden" asp-for="Id" />

                <div class="text-danger mb-3" asp-validation-summary="All"></div>

                <!-- Naziv -->
                <div class="mb-3 row">
                    <label asp-for="OJ" class="col-sm-3 col-form-label">OJ</label>
                    <div class="col-sm-9">
                        <input type="text" asp-for="OJ" class="form-control" placeholder="Unesite OJ" />
                        <span class="text-danger" asp-validation-for="OJ"></span>
                    </div>
                </div>

                <!-- Opština -->
                <div class="mb-3 row">
                    <label asp-for="Naziv" class="col-sm-3 col-form-label">Naziv OJ</label>
                    <div class="col-sm-9">
                        <input type="text" asp-for="Naziv" class="form-control" placeholder="Unesite naziv OJ" />
                        <span class="text-danger" asp-validation-for="Naziv"></span>
                    </div>
                </div>

                <!-- Mesto -->
                <div class="mb-3 row">
                    <label asp-for="GrupaMestaTroskovaId" class="col-sm-3 col-form-label">Grupa mesta troška</label>
                    <div class="col-sm-9">
                        @Html.DropDownListFor(
                                 model => model.GrupaMestaTroskovaId,
                                 ViewBag.Mesta as SelectList,
                                 "Izaberite grupu mesta troška",
                                 new { @class = "form-control" })
                        <span class="text-danger" asp-validation-for="GrupaMestaTroskovaId"></span>
                    </div>
                </div>

                <!-- Submit and Cancel Buttons -->
                <div class="mb-3 row">
                    <div class="col-sm-9 offset-sm-3">
                        <button type="submit" class="btn btn-primary btn-block">Submit</button>
                        <button type="button" class="btn btn-secondary btn-block" onclick="window.location.href='@Url.Action("Index", "Mesta")'">Cancel</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

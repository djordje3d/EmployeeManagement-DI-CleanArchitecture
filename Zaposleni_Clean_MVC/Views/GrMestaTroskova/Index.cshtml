@model List<GrupaMestaTroskova>

<style>
    .active {
        font-weight: bold;
        color: red; /* Ili neka druga boja po izboru */
        text-decoration: underline;
    }
</style>

<div class="container mt-4">
    <h3 class="text-center mb-4">Grupe mesta troškova</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>
                            @{
                                var currentSort = (string)ViewData["CurrentSort"];
                                var isCurrentId = currentSort == "id";
                                var isDescendingId = currentSort == "id_desc";
                                var nextSortId = isCurrentId ? "id_desc" : "id";
                            }
                            <a asp-controller="GrMestaTroskova" asp-action="Index" asp-route-sortOrder="@nextSortId" class="@(isCurrentId || isDescendingId ? "active" : "")">ID Grupa MT</a>
                            <span>
                                @(isCurrentId ? "↑" : isDescendingId ? "↓" : "")
                            </span>
                        </th>

                        <th>
                            @{
                                var isCurrentGrupa = currentSort == "Grupa";
                                var isDescendingGrupa = currentSort == "Grupa_desc";
                                var nextSortGrupa = isCurrentGrupa ? "Grupa_desc" : "Grupa";
                            }
                            <a asp-controller="GrMestaTroskova" asp-action="Index" asp-route-sortOrder="@nextSortGrupa" class="@(isCurrentGrupa || isDescendingGrupa ? "active" : "")">Grupa</a>
                            <span>
                                @(isCurrentGrupa ? "↑" : isDescendingGrupa ? "↓" : "")
                            </span>
                        </th>
                        <th>
                            @{
                                var isCurrentNaziv = currentSort == "Naziv";
                                var isDescendingNaziv = currentSort == "Naziv_desc";
                                var nextSortNaziv = isCurrentNaziv ? "Naziv_desc" : "Naziv";
                            }
                            <a asp-controller="GrMestaTroskova" asp-action="Index" asp-route-sortOrder="@nextSortNaziv" class="@(isCurrentNaziv || isDescendingNaziv ? "active" : "")">Naziv</a>
                            <span>
                                @(isCurrentNaziv ? "↑" : isDescendingNaziv ? "↓" : "")
                            </span>
                        </th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grMestaTroskova in Model)
                    {
                        <tr>
                            <td>@grMestaTroskova.Id</td>
                            <td>@grMestaTroskova.Grupa</td>
                            <td>@grMestaTroskova.Naziv</td>
                            <td>
                                <a class="btn btn-sm btn-warning" asp-action="UpdateGrupaMestaTroskova" asp-route-grMestaTroskovaId="@grMestaTroskova.Id">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a class="btn btn-sm btn-danger" asp-action="DeleteGrupaMestaTroskova" asp-route-grMestaTroskovaId="@grMestaTroskova.Id" onclick="return confirm('Da li ste sigurni da želite da obrišete ovu grupu mesta troškova?');">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-center">Nema grupe mesta troškova.</p>
    }

    <div class="text-center mt-4">
        <a class="btn btn-primary btn-lg" asp-controller="GrMestaTroskova" asp-action="AddGrupaMestaTroskova">
            <i class="bi bi-plus-lg"></i> Add new Grupa mesta troškova
        </a>
    </div>
</div>

@page "/kvalifikacija/add"
@rendermode InteractiveServer

@inject IAddKvalifikacijaUseCase AddKvalifikacijaUseCase
@inject NavigationManager NavigationManager

<h3 class="mt-4">Dodaj novu kvalifikaciju</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="kvalifikacija" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="container-fluid text-start">
        <div class="row g-3">
            <div class="col-12 col-md-2">
                <label for="licniStepenKv" class="form-label">Lični stepen kvalifikacije</label>
                <InputText id="licniStepenKv" class="form-control" @bind-Value="kvalifikacija.LicniStepenKv" placeholder="Unesite stepen kvalifikacije" />
                <ValidationMessage For="@(() => kvalifikacija.LicniStepenKv)" />
            </div>

            <div class="col-12 col-md-4">
                <label for="naziv" class="form-label">Naziv kvalifikacije</label>
                <InputText id="naziv" class="form-control" @bind-Value="kvalifikacija.Naziv" placeholder="Unesite naziv kvalifikacije" />
                <ValidationMessage For="@(() => kvalifikacija.Naziv)" />
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <button type="submit" class="btn btn-success me-2">Sačuvaj</button>
                <button type="button" class="btn btn-secondary" @onclick="VratiSeNaListu">Nazad</button>
            </div>
        </div>
    </div>
</EditForm>


@code {

    private Kvalifikacija kvalifikacija { get; set; } = new Kvalifikacija();
    private string? errorMessage;

    private async Task Save()
    {
        try
        {
            var uspeh = await AddKvalifikacijaUseCase.ExecuteAsync(kvalifikacija);

            if (uspeh)
            {
                Console.WriteLine($"Uspešno sačuvana kvalifikacija: {kvalifikacija.Naziv}");
                NavigationManager.NavigateTo("/kvalifikacije"); // Povratak na listu kvalifikacija
            }
            else
            {
                errorMessage = "Greška pri čuvanju kvalifikacije. Pokušajte ponovo.";
                Console.WriteLine("Došlo je do greške pri dodavanju kvalifikacije.");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Došlo je do neočekivane greške: {ex.Message}";
            Console.WriteLine($"Izuzetak: {ex}");
        }
    }
    private void VratiSeNaListu()
    {
        NavigationManager.NavigateTo("/kvalifikacije");
    }
}

@page "/mesta/edit/{id:int}"
@using Zaposleni_Blazor.UseCases.Mesta

@rendermode InteractiveServer

@inject IMestoByIdUseCase MestoByIdUseCase
@inject IEditMestoUseCase EditMestoUseCase
@inject NavigationManager NavigationManager

<h3 class="mt-4">Izmeni mesto</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (mesto == null)
{
    <p>⏳ Učitavanje podataka...</p>
}
else
{
    <EditForm Model="mesto" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="container-fluid text-start">
        <div class="row g-3">
            <div class="col-12 col-md-2">
                <label for="naziv" class="form-label">Naziv mesta</label>
                <InputText id="naziv" class="form-control" @bind-Value="mesto.Naziv" placeholder="Unesite naziv mesta" />
                <ValidationMessage For="@(() => mesto.Naziv)" />
            </div>
            <div class="col-12 col-md-2">
                <label for="opstina" class="form-label">Naziv opštine</label>
                <InputText id="opstina" class="form-control" @bind-Value="mesto.Opstina" placeholder="Unesite naziv opštine" />
                <ValidationMessage For="@(() => mesto.Opstina)" />
            </div>
            <div class="col-12 col-md-2">
                <label for="postanskiBroj" class="form-label">Poštanski broj</label>
                <InputText id="postanskiBroj" class="form-control" @bind-Value="mesto.PostanskiBroj" placeholder="Unesite poštanski broj" />
                <ValidationMessage For="@(() => mesto.PostanskiBroj)" />
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <button type="submit" class="btn btn-success me-2">Sačuvaj</button>
                <button type="button" class="btn btn-secondary" @onclick="VratiSeNaListu">Nazad</button>
            </div>
        </div>
    </div>
</EditForm>

}

@code {
    [Parameter] public int id { get; set; }

    private Mesto? mesto;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            mesto = await MestoByIdUseCase.ExecuteAsync(id);

            if (mesto == null)
            {
                errorMessage = "Mesto nije pronađeno.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Došlo je do greške pri učitavanju podataka: {ex.Message}";
        }
    }

    private async Task Save()
    {
        try
        {
            var success = await EditMestoUseCase.ExecuteAsync(mesto!);

            if (success)
            {
                Console.WriteLine($"Uspešno sačuvano mesto: {mesto.Naziv}");
                NavigationManager.NavigateTo("/mesta");
            }
            else
            {
                errorMessage = "Greška pri snimanju izmena.";
                Console.WriteLine("Došlo je do greške pri izmeni mesta.");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Greška: {ex.Message}";
        }
    }

    private void VratiSeNaListu()
    {
        NavigationManager.NavigateTo("/mesta");
    }
}
